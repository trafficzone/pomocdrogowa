---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Transport lawetą',
    desc: 'Przewóz pojazdów osobowych, dostawczych i motocykli na terenie regionu. Bezpieczny transport po awarii, wypadku lub kolizji.',
    icon: 'M3 13h13l3 5h2M3 13V7a1 1 0 011-1h8l4 5M3 13v5h2m10 0h2m-8 0a2 2 0 11-4 0 2 2 0 014 0zm10 0a2 2 0 11-4 0 2 2 0 014 0z',
  },
  {
    title: 'Naprawy na drodze',
    desc: 'Wymiana koła, rozruch akumulatora, drobne naprawy mechaniczne i elektryczne wykonane na miejscu zdarzenia.',
    icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z',
  },
  {
    title: 'Własny warsztat',
    desc: 'Naprawy mechaniczne wykonujemy także we własnym warsztacie, pod tym samym adresem co lawetowanie.',
    icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z',
  },
  {
    title: 'Pomoc po wypadku',
    desc: 'Zabezpieczenie miejsca zdarzenia oraz bezpieczny transport pojazdu uszkodzonego po wypadku.',
    icon: 'M12 9v2m0 4h.01M10.29 3.86l-8.18 14.18A1 1 0 003 19.5h18a1 1 0 00.89-1.46L13.71 3.86a1 1 0 00-1.42 0z',
  },
  {
    title: 'Dowóz paliwa',
    desc: 'Skończyło się paliwo w trasie? Dowozimy niezbędną ilość, abyś mógł bezpiecznie dojechać do najbliższej stacji.',
    icon: 'M5 21V7a2 2 0 012-2h6a2 2 0 012 2v14M5 21h10m-10 0H3m12 0h2m4-9h-2a2 2 0 00-2 2v7m4-9V8a2 2 0 00-2-2h-1m3 5l-3-3',
  },
  {
    title: 'Transport specjalny',
    desc: 'Przewóz pojazdów nietypowych, uszkodzonych lub niesprawnych — również po wypadkach z dużymi uszkodzeniami.',
    icon: 'M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z',
  },
];
---

<Layout
  title="Usługi | Pomoc Drogowa"
  description="Pełen zakres usług pomocy drogowej — laweta, naprawy na drodze i we własnym warsztacie, dowóz paliwa, transport specjalny."
>
  <!-- Hero -->
  <section class="relative bg-gray-950 pt-20 pb-20 overflow-hidden">
    <div class="wrap relative text-center">
      <span class="eyebrow bg-white/10 text-gray-300">Nasze usługi</span>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">Pełen zakres pomocy drogowej</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">Niezależnie od sytuacji na drodze — działamy szybko, profesjonalnie i całą dobę.</p>
    </div>
  </section>

  <!-- Lista usług -->
  <section class="section bg-white">
    <div class="wrap">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s, i) => (
          <div class="card p-8 reveal" style={`transition-delay:${(i % 3) * 0.1}s`}>
            <div class="w-14 h-14 bg-orange-50 rounded-xl flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d={s.icon}/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{s.title}</h3>
            <p class="text-gray-500 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 lg:py-24 overflow-hidden bg-pd-orange">
    <div class="relative wrap text-center">
      <h2 class="text-3xl lg:text-5xl font-extrabold text-white mb-4 leading-tight">
        Nie widzisz swojej sytuacji na liście?
      </h2>
      <p class="text-white/80 text-lg mb-10 max-w-xl mx-auto">
        Zadzwoń — ocenimy sytuację i zaproponujemy najlepsze rozwiązanie.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+48609116309" class="btn-white text-lg px-8 py-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Zadzwoń teraz
        </a>
        <a href="/kontakt" class="btn-outline text-lg px-8 py-4">
          Napisz do nas
        </a>
      </div>
    </div>
  </section>
</Layout>
