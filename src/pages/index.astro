---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout
  title="Laweta Kartuzy 24/7 | AutoMania Andrzej Radomski"
  description="Laweta Kartuzy całą dobę — AutoMania Andrzej Radomski. Pomoc drogowa 24/7, transport pojazdu lawetą, warsztat mechaniczny na miejscu. Obsługujemy Kartuzy, Trójmiasto, Żukowo i okolice. Tel: 609 116 309."
>

  <!-- ═══════════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════════ -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1601362840469-51e4d8d58785?w=1920&q=80&auto=format"
        alt="Laweta pomocy drogowej"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-gray-950/95 via-gray-900/85 to-gray-900/50"></div>
    </div>

    <div class="relative wrap py-28 lg:py-36 w-full">
      <div class="max-w-2xl">
        <!-- Eyebrow pill -->
        <div class="inline-flex items-center gap-2.5 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-8">
          <span class="w-2 h-2 rounded-full bg-pd-orange animate-pulse"></span>
          <span class="text-white/80 text-sm font-medium">Dostępni 24 godziny na dobę</span>
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-white leading-[1.05] mb-6 tracking-tight">
          Pomoc drogowa<br/>
          <span class="text-pd-orange">zawsze</span><br/>
          gdy jej potrzebujesz
        </h1>

        <p class="text-gray-300 text-lg sm:text-xl leading-relaxed mb-10 max-w-xl">
          Awaria, stłuczka, brak paliwa? Jesteśmy na miejscu szybko — całodobowo,
          na terenie całego regionu. Laweta, naprawy na drodze i we własnym warsztacie.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-14">
          <a href="tel:+48609116309" class="btn-primary text-lg px-8 py-4">
            Zadzwoń teraz
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href="#uslugi" class="btn-outline text-lg px-8 py-4">
            Nasze usługi
          </a>
        </div>

        <!-- Trust bar -->
        <div class="flex flex-wrap gap-x-7 gap-y-2">
          {['✓ Dojazd 24/7', '✓ Szybka reakcja', '✓ Uczciwe ceny', '✓ Pomoc w regionie'].map(item => (
            <span class="text-gray-400 text-sm font-medium">{item}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       USŁUGI
  ════════════════════════════════════════════════════════ -->
  <section id="uslugi" class="section bg-gray-50">
    <div class="wrap">
      <div class="text-center mb-14">
        <span class="eyebrow bg-orange-50 text-pd-orange">Co robimy</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Pomoc na każdą okazję</h2>
        <p class="text-gray-500 text-lg">Kompleksowa pomoc drogowa dostępna całą dobę</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Laweta -->
        <a href={`${base}uslugi`} class="card group p-8 border-t-4 border-t-pd-orange block reveal reveal-delay-1">
          <div class="w-14 h-14 bg-orange-50 rounded-xl flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13h13l3 5h2M3 13V7a1 1 0 011-1h8l4 5M3 13v5h2m10 0h2m-8 0a2 2 0 11-4 0 2 2 0 014 0zm10 0a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Transport lawetą</h3>
          <p class="text-gray-500 leading-relaxed mb-6">Przewóz pojazdów osobowych i dostawczych na terenie regionu. Bezpieczny transport po awarii lub wypadku.</p>
          <span class="text-pd-orange font-semibold text-sm flex items-center gap-1 group-hover:gap-3 transition-all">
            Sprawdź szczegóły
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <!-- Naprawy na drodze -->
        <a href={`${base}uslugi`} class="card group p-8 border-t-4 border-t-pd-yellow block reveal reveal-delay-2">
          <div class="w-14 h-14 bg-yellow-50 rounded-xl flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-pd-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Naprawy na drodze</h3>
          <p class="text-gray-500 leading-relaxed mb-6">Wymiana koła, rozruch akumulatora, drobne naprawy mechaniczne wykonane na miejscu zdarzenia.</p>
          <span class="text-pd-yellow font-semibold text-sm flex items-center gap-1 group-hover:gap-3 transition-all">
            Sprawdź szczegóły
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <!-- Własny warsztat -->
        <a href={`${base}uslugi`} class="card group p-8 border-t-4 border-t-gray-700 block reveal reveal-delay-3">
          <div class="w-14 h-14 bg-gray-100 rounded-xl flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Własny warsztat</h3>
          <p class="text-gray-500 leading-relaxed mb-6">Naprawy mechaniczne wykonujemy także we własnym warsztacie pod tym samym adresem, co lawetowanie.</p>
          <span class="text-gray-700 font-semibold text-sm flex items-center gap-1 group-hover:gap-3 transition-all">
            Sprawdź szczegóły
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       O NAS PREVIEW
  ════════════════════════════════════════════════════════ -->
  <section class="section bg-white">
    <div class="wrap">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="eyebrow bg-orange-50 text-pd-orange">O firmie</span>
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-6 leading-tight">
            Pomagamy kierowcom od wielu lat
          </h2>
          <p class="text-gray-500 text-lg leading-relaxed mb-5">
            Pomoc Drogowa to zespół doświadczonych kierowców lawet i mechaników, gotowych
            do działania w każdej sytuacji na drodze. Działamy szybko i profesjonalnie,
            bez względu na pogodę czy godzinę.
          </p>
          <p class="text-gray-500 leading-relaxed mb-10">
            Współpracujemy z klientami indywidualnymi oraz firmami transportowymi.
            Pełna dyspozycyjność, jasne zasady rozliczeń.
          </p>

          <!-- Stats -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
            {[
              { v: '24/7', l: 'dostępność' },
              { v: '1000+', l: 'zrealizowanych zleceń' },
              { v: '30 min', l: 'średni czas dojazdu' },
              { v: '100%', l: 'zadowolonych klientów' },
            ].map(s => (
              <div class="text-center bg-gray-50 rounded-xl p-4">
                <div class="text-2xl lg:text-3xl font-extrabold text-pd-orange">{s.v}</div>
                <div class="text-xs text-gray-500 mt-0.5 leading-tight">{s.l}</div>
              </div>
            ))}
          </div>

          <a href={`${base}o-nas`} class="inline-flex items-center gap-2 text-pd-orange font-semibold hover:gap-4 transition-all">
            Poznaj naszą firmę
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <!-- Image -->
        <div class="relative">
          <div class="rounded-2xl overflow-hidden aspect-[4/3] shadow-2xl">
            <img
              src="/laweta.png"
              alt="Laweta w trasie"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Badge -->
          <div class="absolute -bottom-5 -left-5 bg-white rounded-2xl shadow-xl p-4 flex items-center gap-3">
            <div class="w-11 h-11 bg-green-100 rounded-xl flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <div class="text-sm font-bold text-gray-900">Czynne 24/7</div>
              <div class="text-xs text-gray-500">Również w święta</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       DLACZEGO MY
  ════════════════════════════════════════════════════════ -->
  <section class="section bg-gray-950">
    <div class="wrap">
      <div class="text-center mb-14">
        <span class="eyebrow bg-white/10 text-gray-300">Dlaczego my</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4">Dlaczego wybierają nas kierowcy</h2>
        <p class="text-gray-400 text-lg max-w-lg mx-auto">Szybko, uczciwie i bez stresu — niezależnie od sytuacji</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Dostępność 24/7', desc: 'Pomagamy w dzień i w nocy, w święta i weekendy. Zawsze gdy nas potrzebujesz.' },
          { icon: 'M3 13h13l3 5h2M3 13V7a1 1 0 011-1h8l4 5M3 13v5h2m10 0h2', title: 'Szybki dojazd', desc: 'Działamy lokalnie i regionalnie — staramy się być na miejscu jak najszybciej.' },
          { icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z', title: 'Doświadczona ekipa', desc: 'Wykwalifikowani kierowcy lawet i mechanicy z wieloletnią praktyką w terenie.' },
          { icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Uczciwe ceny', desc: 'Jasna wycena przed wykonaniem usługi. Żadnych skrytych opłat ani niespodzianek.' },
          { icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z', title: 'Własny warsztat', desc: 'Naprawy mechaniczne wykonujemy także we własnym warsztacie, pod tym samym adresem co lawetowanie.' },
          { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Zaufanie klientów', desc: 'Wysoko oceniani przez naszych klientów — sprawdź opinie z Google poniżej.' },
        ].map((item, i) => (
          <div class="bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl p-6 transition-colors reveal" style={`transition-delay:${i * 0.08}s`}>
            <div class="w-12 h-12 bg-pd-orange/20 rounded-xl flex items-center justify-center mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
              </svg>
            </div>
            <h3 class="text-white font-bold text-lg mb-2">{item.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       JAK DZIAŁAMY
  ════════════════════════════════════════════════════════ -->
  <section class="section bg-white">
    <div class="wrap">
      <div class="text-center mb-14">
        <span class="eyebrow bg-orange-50 text-pd-orange">Proces</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Jak przebiega pomoc</h2>
        <p class="text-gray-500 text-lg">Prosty proces — bez zbędnych formalności</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { n: '01', t: 'Zgłoszenie', d: 'Zadzwoń i opisz sytuację oraz swoją lokalizację. Odbieramy całą dobę.' },
          { n: '02', t: 'Dojazd', d: 'Najbliższa dostępna ekipa wyrusza do Ciebie. Informujemy o szacowanym czasie.' },
          { n: '03', t: 'Pomoc na miejscu', d: 'Naprawa na drodze lub załadunek na lawetę — w zależności od sytuacji.' },
          { n: '04', t: 'Rozliczenie', d: 'Jasna wycena i przejrzyste zasady płatności po wykonaniu usługi.' },
        ].map((step, i) => (
          <div class="relative">
            {i < 3 && (
              <div class="hidden lg:block absolute top-8 left-full w-full border-t-2 border-dashed border-gray-200 z-0"></div>
            )}
            <div class="relative z-10">
              <div class="w-16 h-16 bg-pd-orange rounded-2xl flex items-center justify-center mb-5 shadow-lg shadow-orange-900/20">
                <span class="text-white font-extrabold text-lg">{step.n}</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{step.t}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{step.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       OPINIE
  ════════════════════════════════════════════════════════ -->
  <section class="section bg-gray-50">
    <div class="wrap">
      <div class="text-center mb-14">
        <span class="eyebrow bg-orange-50 text-pd-orange">Opinie klientów</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-2">Co mówią o nas klienci</h2>
        <p class="text-gray-500">Prawdziwe opinie naszych klientów z Google</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { name: 'Jacek Migala', role: '9 miesięcy temu', text: 'Rewelacja! Szef firmy i majster pomógł mi w sytuacji dla mnie bardzo kryzysowej, dla szefa w wolnym czasie. Szybko, z pomysłem i profesjonalnie uporał się z usterką. Polecam szczerze.' },
          { name: 'Maciej Radomski', role: '9 miesięcy temu', text: 'Rzetelny, bardzo rzeczowy i bierze do serca auto, które mu dajesz. Obsługa ciepła i chce się tam przyjeżdżać nie tylko na naprawy.' },
          { name: 'Tom Jel', role: 'rok temu', text: 'Super serwis! Bardzo miły Pan. Pomógł nam nawet poza czasem otwarcia! Naprawdę polecam i dziękuję za pomoc!' },
          { name: 'Krzysztof Cyrzan', role: '2 lata temu', text: 'Fachowa, rzeczowa pomoc. Mechanik zna się na swojej robocie, mogę śmiało polecić. Dodatkowym atutem są przystępne ceny!' },
          { name: 'Kornelia Szuta', role: 'rok temu', text: 'Polecamy, pomoc wulkanizacyjna od ręki, pomimo że było poza godzinami pracy :)' },
          { name: 'krystyna plich', role: '6 lat temu', text: 'Polecam. Pan Andrzej uratował mnie w awaryjnej sytuacji. Super fachowiec. Polecam!' },
        ].map((r, i) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm reveal" style={`transition-delay:${i * 0.12}s`}>
            <div class="flex text-pd-yellow mb-4">
              {Array(5).fill(null).map(() => <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
            </div>
            <p class="text-gray-600 leading-relaxed mb-5 italic">&ldquo;{r.text}&rdquo;</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gray-200 rounded-full flex items-center justify-center text-gray-500 font-bold text-sm">{r.name[0]}</div>
              <div>
                <div class="font-semibold text-gray-900 text-sm">{r.name}</div>
                <div class="text-gray-400 text-xs">{r.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       CTA BANNER
  ════════════════════════════════════════════════════════ -->
  <section class="relative py-20 lg:py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1601362840469-51e4d8d58785?w=1920&q=80&auto=format"
        alt=""
