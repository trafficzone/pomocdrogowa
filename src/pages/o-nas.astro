---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout
  title="O nas | AutoMania Andrzej Radomski — Pomoc Drogowa i Warsztat"
  description="AutoMania Andrzej Radomski — doświadczony warsztat mechaniczny i pomoc drogowa 24/7. Lawetowanie, naprawy, mechanika. Sprawdź gdzie jesteśmy."
>
  <!-- Hero -->
  <section class="relative bg-gray-950 pt-20 pb-20 overflow-hidden">
    <div class="wrap relative text-center">
      <span class="eyebrow bg-white/10 text-gray-300">O firmie</span>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">AutoMania Andrzej Radomski</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">Warsztat mechaniczny i pomoc drogowa 24/7 — szybko, uczciwie i profesjonalnie.</p>
    </div>
  </section>

  <!-- Główna treść -->
  <section class="section bg-white">
    <div class="wrap">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="eyebrow bg-orange-50 text-pd-orange">Nasza historia</span>
          <h2 class="text-3xl font-bold text-gray-900 mb-5 leading-tight">Firma z pasją do motoryzacji</h2>
          <p class="text-gray-500 text-lg leading-relaxed mb-5">
            <strong class="text-gray-800">AutoMania</strong> to firma założona i prowadzona przez <strong class="text-gray-800">Andrzeja Radomskiego</strong> —
            mechanika z wieloletnim doświadczeniem w branży motoryzacyjnej. Przez lata pracy zdobył zaufanie
            setek kierowców, którzy wracają do nas nie tylko po naprawy, ale i po rzetelną poradę.
          </p>
          <p class="text-gray-500 leading-relaxed mb-5">
            Specjalizujemy się w kompleksowej mechanice samochodowej oraz pomocy drogowej dostępnej
            całą dobę. Nasz warsztat to miejsce, gdzie każdy samochód traktowany jest z należytą uwagą —
            niezależnie od marki, modelu czy roku produkcji.
          </p>
          <p class="text-gray-500 leading-relaxed mb-10">
            Współpracujemy zarówno z klientami indywidualnymi, jak i z firmami posiadającymi floty pojazdów.
            Stawiamy na szybkość reakcji i przejrzyste zasady rozliczeń — bez ukrytych kosztów i nieprzyjemnych niespodzianek.
          </p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            {[
              { v: '24/7', l: 'dostępność' },
              { v: '1000+', l: 'zrealizowanych zleceń' },
              { v: '30 min', l: 'średni czas dojazdu' },
              { v: '100%', l: 'zadowolonych klientów' },
            ].map(s => (
              <div class="text-center bg-gray-50 rounded-xl p-4">
                <div class="text-2xl lg:text-3xl font-extrabold text-pd-orange">{s.v}</div>
                <div class="text-xs text-gray-500 mt-0.5 leading-tight">{s.l}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="relative">
          <div class="rounded-2xl overflow-hidden aspect-[4/3] shadow-2xl">
            <img
              src="https://images.unsplash.com/photo-1565043666747-69f6646db940?w=800&q=80&auto=format"
              alt="Mechanik AutoMania przy pracy"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Warsztat -->
  <section class="section bg-gray-50">
    <div class="wrap">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <div class="order-2 lg:order-1">
          <div class="rounded-2xl overflow-hidden aspect-[4/3] shadow-2xl">
            <img
              src="https://images.unsplash.com/photo-1625047509248-ec889cbff17f?w=800&q=80&auto=format"
              alt="Wnętrze warsztatu mechanicznego AutoMania"
              class="w-full h-full object-cover"
            />
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <span class="eyebrow bg-orange-50 text-pd-orange">Warsztat mechaniczny</span>
          <h2 class="text-3xl font-bold text-gray-900 mb-5 leading-tight">Własny warsztat na miejscu</h2>
          <p class="text-gray-500 text-lg leading-relaxed mb-5">
            W skład naszej działalności wchodzi w pełni wyposażony warsztat mechaniczny,
            w którym wykonujemy naprawy wszystkich marek i modeli samochodów osobowych oraz dostawczych.
          </p>
          <ul class="space-y-3 mb-8">
            {[
              'Diagnostyka komputerowa',
              'Naprawy silnika i układu napędowego',
              'Wymiana olejów, filtrów i płynów eksploatacyjnych',
              'Naprawa i regulacja układu hamulcowego',
              'Wymiana rozrządu i sprzęgła',
              'Geometria kół i wyważanie',
              'Naprawy elektryki samochodowej',
              'Wulkanizacja i wymiana opon',
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-600">
                <span class="w-5 h-5 rounded-full bg-pd-orange/15 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
          <a href={`${base}uslugi`} class="inline-flex items-center gap-2 text-pd-orange font-semibold hover:gap-4 transition-all">
            Zobacz wszystkie usługi
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Lokalizacja -->
  <section class="section bg-white">
    <div class="wrap">
      <div class="text-center mb-14">
        <span class="eyebrow bg-orange-50 text-pd-orange">Znajdź nas</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900">Gdzie jesteśmy</h2>
        <p class="text-gray-500 text-lg mt-3">Zapraszamy do naszego warsztatu lub dzwoń — przyjedziemy do Ciebie</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
        <div class="card p-8 text-center">
          <div class="w-14 h-14 bg-orange-50 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Adres warsztatu</h3>
          <p class="text-gray-500 leading-relaxed">
            AutoMania Andrzej Radomski<br/>
            ul. Świerkowa 3<br/>
            83-300 Kartuzy
          </p>
        </div>

        <div class="card p-8 text-center">
          <div class="w-14 h-14 bg-orange-50 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Telefon</h3>
          <p class="text-gray-500 leading-relaxed">
            Pomoc drogowa 24/7:<br/>
            <a href="tel:+48609116309" class="text-pd-orange font-bold text-lg hover:underline">609 116 309</a>
          </p>
        </div>

        <div class="card p-8 text-center">
          <div class="w-14 h-14 bg-orange-50 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Godziny otwarcia</h3>
          <p class="text-gray-500 leading-relaxed">
            Pon–Pt: 8:00–17:00<br/>
            Sobota: 8:00–14:00<br/>
            <span class="text-pd-orange font-semibold">Pomoc drogowa: całą dobę</span>
          </p>
        </div>
      </div>

      <!-- Mapa placeholder -->
      <div class="rounded-2xl overflow-hidden shadow-xl h-80 bg-gray-200 flex items-center justify-center">
        <div class="text-center text-gray-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mx-auto mb-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          <p class="font-medium">Mapa dojazdu</p>
          <p class="text-sm">AutoMania Andrzej Radomski</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wartości -->
  <section class="section bg-gray-50">
    <div class="wrap">
      <div class="text-center mb-14">
        <span class="eyebrow bg-orange-50 text-pd-orange">Nasze wartości</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900">Czym się kierujemy</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { title: 'Szybkość', desc: 'Każda minuta jest ważna — staramy się być na miejscu jak najszybciej. Dysponujemy własną lawetą gotową do wyjazdu całą dobę.' },
          { title: 'Uczciwość', desc: 'Jasna wycena przed wykonaniem usługi, bez ukrytych kosztów. Pan Andrzej osobiście dba o to, żeby każdy klient wiedział za co płaci.' },
          { title: 'Profesjonalizm', desc: 'Wieloletnie doświadczenie i odpowiedni sprzęt do każdej sytuacji na drodze. Pracujemy na markowych częściach i sprawdzonym oprzyrządowaniu.' },
        ].map(v => (
          <div class="card p-8 text-center">
            <h3 class="text-xl font-bold text-gray-900 mb-3">{v.title}</h3>
            <p class="text-gray-500 leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-gray-950">
    <div class="wrap text-center">
      <h2 class="text-3xl lg:text-4xl font-extrabold text-white mb-4">Masz pytania? Zadzwoń do nas</h2>
      <p class="text-gray-400 text-lg mb-8 max-w-xl mx-auto">
        AutoMania Andrzej Radomski — warsztat i pomoc drogowa. Jesteśmy do Twojej dyspozycji.
      </p>
      <a href="tel:+48609116309" class="btn-primary text-lg px-8 py-4">
        609 116 309
      </a>
    </div>
  </section>
</Layout>
