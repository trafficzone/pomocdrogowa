---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout
  title="Laweta Pruszcz Gdański — pomoc drogowa 24/7 | AutoMania"
  description="Laweta Pruszcz Gdański i okolice A1 — AutoMania Kartuzy. Transport pojazdu, pomoc po wypadku całą dobę. Zadzwoń: 609 116 309."
>
  <section class="relative bg-gray-950 pt-20 pb-16">
    <div class="wrap max-w-3xl">
      <a href={`${base}blog`} class="inline-flex items-center gap-2 text-gray-400 hover:text-white text-sm mb-8 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Powrót do bloga
      </a>
      <span class="eyebrow bg-white/10 text-gray-300">Pomoc drogowa · Pruszcz Gdański</span>
      <h1 class="text-3xl lg:text-4xl font-extrabold text-white mb-4 leading-tight">Laweta Pruszcz Gdański — pomoc drogowa i transport pojazdu</h1>
      <div class="flex items-center gap-3 text-gray-400 text-sm">
        <span>AutoMania Andrzej Radomski · Kartuzy</span>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="wrap max-w-3xl">
      <div class="bg-pd-orange rounded-2xl p-7 text-center mb-10">
        <p class="text-orange-100 mb-2">Awaria w Pruszczu Gdańskim?</p>
        <a href="tel:+48609116309" class="text-white font-extrabold text-4xl tracking-tight hover:underline">609 116 309</a>
        <p class="text-orange-100 mt-2 text-sm">Dostępni 24/7 · Dojazd do Pruszcza i okolic A1</p>
      </div>

      <div class="prose prose-lg max-w-none text-gray-600">
        <p class="text-xl text-gray-700 leading-relaxed mb-8">
          <strong class="text-gray-900">Laweta Pruszcz Gdański</strong> — AutoMania obsługuje Pruszcz Gdański,
          okolice autostrady A1 oraz gminy Pruszcz Gdański i Kolbudy. Pruszcz leży na kluczowym węźle
          komunikacyjnym — tu krzyżuje się autostrada A1, droga krajowa nr 7 i Obwodnica Południowa Trójmiasta.
          To miejsce, gdzie awarie zdarzają się szczególnie często.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mb-4 mt-10">Awaria na A1 i obwodnicy — co robić?</h2>
        <p class="mb-5">
          Autostrada A1 w okolicach Pruszcza Gdańskiego to jeden z najbardziej ruchliwych odcinków
          w Polsce Północnej. Awaria tutaj wymaga natychmiastowej reakcji — włącz awaryjne, zejdź
          z jezdni i zadzwoń po lawetę. Dysponujemy sprzętem do obsługi autostrad i dojedziemy do Ciebie szybko.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mb-4 mt-10">Obszar obsługi</h2>
        <ul class="grid grid-cols-2 gap-2 mb-8 list-none">
          {['Pruszcz Gdański', 'Kolbudy', 'Juszkowo', 'Wojanowo', 'Łęgowo', 'Wiślina', 'Straszyn', 'Bąkowo'].map(m => (
            <li class="flex items-center gap-2 text-gray-600">
              <span class="w-1.5 h-1.5 rounded-full bg-pd-orange flex-shrink-0"></span>
              {m}
            </li>
          ))}
        </ul>

        <div class="bg-orange-50 border border-orange-100 rounded-2xl p-8 mt-8">
          <h3 class="text-xl font-bold text-gray-900 mb-2">AutoMania — laweta Pruszcz Gdański</h3>
          <p class="text-gray-600 mb-5">Całodobowa pomoc drogowa. Transport lawetą do warsztatu lub wskazanego miejsca.</p>
          <a href="tel:+48609116309" class="btn-primary">Zadzwoń: 609 116 309</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-gray-50">
    <div class="wrap max-w-3xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Inne obszary działania</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href={`${base}blog/laweta-gdansk`} class="card p-5 group block text-center">
          <h3 class="font-bold text-gray-900 group-hover:text-pd-orange transition-colors">Laweta Gdańsk</h3>
        </a>
        <a href={`${base}blog/laweta-kartuzy`} class="card p-5 group block text-center">
          <h3 class="font-bold text-gray-900 group-hover:text-pd-orange transition-colors">Laweta Kartuzy</h3>
        </a>
        <a href={`${base}blog/laweta-trojmiasto`} class="card p-5 group block text-center">
          <h3 class="font-bold text-gray-900 group-hover:text-pd-orange transition-colors">Laweta Trójmiasto</h3>
        </a>
      </div>
    </div>
  </section>
</Layout>
