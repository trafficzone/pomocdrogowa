---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const localPosts = [
  { slug: 'laweta-kartuzy', title: 'Laweta Kartuzy — pomoc drogowa 24/7', excerpt: 'Szukasz lawety w Kartuzach? AutoMania Andrzej Radomski to lokalna firma z siedzibą przy ul. Świerkowej 3 — szybki dojazd na terenie Kartuz i całego powiatu.', date: '1 lipca 2025', readTime: '4 min' },
  { slug: 'laweta-zukowo', title: 'Laweta Żukowo — pomoc drogowa i transport pojazdu', excerpt: 'Awaria w Żukowie lub na trasie przez Chwaszczyno i Banino? AutoMania z Kartuz dotrze do Ciebie w około 10 minut.', date: '1 lipca 2025', readTime: '4 min' },
  { slug: 'laweta-gdansk', title: 'Laweta Gdańsk — transport pojazdu i pomoc drogowa', excerpt: 'Obsługujemy Gdańsk i okolice całą dobę. Szybki dojazd z Kartuz, transport do warsztatu lub wskazanego miejsca.', date: '1 lipca 2025', readTime: '4 min' },
  { slug: 'laweta-gdynia', title: 'Laweta Gdynia — szybki transport pojazdu całą dobę', excerpt: 'Laweta Gdynia — AutoMania z Kartuz obsługuje Gdynię i okoliczne dzielnice. Dojazd ok. 25 minut z Kartuz.', date: '1 lipca 2025', readTime: '4 min' },
  { slug: 'laweta-trojmiasto', title: 'Laweta Trójmiasto — Gdańsk, Gdynia, Sopot i okolice', excerpt: 'Obsługujemy cały obszar metropolitalny Trójmiasta. Własna laweta, uczciwa cena, dojazd całą dobę.', date: '1 lipca 2025', readTime: '5 min' },
  { slug: 'laweta-pruszcz-gdanski', title: 'Laweta Pruszcz Gdański — pomoc drogowa i A1', excerpt: 'Awaria na A1 lub obwodnicy w okolicach Pruszcza Gdańskiego? AutoMania przyjedzie szybko.', date: '1 lipca 2025', readTime: '3 min' },
  { slug: 'laweta-wejherowo', title: 'Laweta Wejherowo, Rumia, Reda — pomoc drogowa 24/7', excerpt: 'Obsługujemy powiat wejherowski i trasę S6 w kierunku Lęborka. Całodobowa pomoc drogowa.', date: '1 lipca 2025', readTime: '3 min' },
  { slug: 'laweta-koscierzyna', title: 'Laweta Kościerzyna — transport pojazdu z Kartuz', excerpt: 'Kościerzyna leży 25 km od Kartuz — docieramy szybko na całej trasie drogi nr 20.', date: '1 lipca 2025', readTime: '3 min' },
  { slug: 'laweta-lebork', title: 'Laweta Lębork — pomoc drogowa na trasie S6', excerpt: 'Obsługujemy trasy S6 (Via Baltica) na odcinku Wejherowo–Lębork. Transport całą dobę.', date: '1 lipca 2025', readTime: '3 min' },
];

const posts = [
  {
    slug: 'co-robic-gdy-samochod-sie-psuje-na-drodze',
    title: 'Co zrobić, gdy samochód psuje się na drodze?',
    excerpt: 'Awaria w trasie to stresująca sytuacja. Poznaj krok po kroku, jak zachować się bezpiecznie i jak najszybciej uzyskać pomoc drogową.',
    date: '10 czerwca 2025',
    readTime: '5 min',
  },
  {
    slug: 'laweta-kiedy-i-jak-dziala',
    title: 'Laweta — kiedy jej potrzebujesz i jak działa transport?',
    excerpt: 'Nie każda awaria kończy się naprawą na miejscu. Dowiedz się, kiedy konieczny jest transport lawetą i na co zwrócić uwagę przy wyborze usługi.',
    date: '18 czerwca 2025',
    readTime: '6 min',
  },
  {
    slug: 'najczestsze-awarie-samochodowe',
    title: 'Najczęstsze awarie samochodowe i jak im zapobiec',
    excerpt: 'Dowiedz się, jakie usterki najczęściej unieruchamiają kierowców i co możesz zrobić, żeby nie zostać z autem na środku drogi.',
    date: '25 czerwca 2025',
    readTime: '7 min',
  },
  {
    slug: 'jak-zadbac-o-akumulator-samochodowy',
    title: 'Jak zadbać o akumulator samochodowy? Poradnik kierowcy',
    excerpt: 'Rozładowany akumulator to jedna z najczęstszych przyczyn wezwania pomocy drogowej. Sprawdź, jak go pielęgnować i kiedy wymienić.',
    date: '2 maja 2025',
    readTime: '5 min',
  },
  {
    slug: 'wymiana-kola-na-drodze',
    title: 'Wymiana koła na drodze — kiedy sam, kiedy wezwać pomoc?',
    excerpt: 'Przebita opona to klasyk. Sprawdź, kiedy warto zmienić koło samemu, a kiedy lepiej zadzwonić do pomocy drogowej — zwłaszcza nocą lub na autostradzie.',
    date: '14 maja 2025',
    readTime: '4 min',
  },
  {
    slug: 'pomoc-drogowa-24-7-dlaczego-wazna',
    title: 'Pomoc drogowa 24/7 — dlaczego całodobowa dostępność jest tak ważna?',
    excerpt: 'Awarie nie pytają o porę dnia. Dowiedz się, dlaczego warto mieć pod ręką numer do całodobowej pomocy drogowej i co różni dobre serwisy od tych słabych.',
    date: '28 kwietnia 2025',
    readTime: '4 min',
  },
  {
    slug: 'transport-samochodu-laweta-co-warto-wiedziec',
    title: 'Transport samochodu lawetą — co warto wiedzieć przed zleceniem?',
    excerpt: 'Zanim zlecisz transport lawetą, sprawdź co powinieneś wiedzieć: jak wygląda załadunek, ile kosztuje, co wpływa na cenę i jakie są Twoje prawa jako klient.',
    date: '7 maja 2025',
    readTime: '6 min',
  },
  {
    slug: 'awaria-na-autostradzie-co-robic',
    title: 'Awaria na autostradzie — jak się zachować i kto może pomóc?',
    excerpt: 'Autostrada to szczególnie niebezpieczne miejsce na awarię. Poznaj zasady bezpiecznego postępowania i dowiedz się, jak szybko wezwać lawetę.',
    date: '20 maja 2025',
    readTime: '5 min',
  },
];
---

<Layout
  title="Blog motoryzacyjny | AutoMania — Laweta, naprawy, pomoc drogowa"
  description="Artykuły i porady motoryzacyjne od AutoMania Andrzej Radomski. Dowiedz się więcej o pomocy drogowej, lawetowaniu i naprawach samochodowych."
>
  <section class="relative bg-gray-950 pt-20 pb-20">
    <div class="wrap text-center">
      <span class="eyebrow bg-white/10 text-gray-300">Wiedza motoryzacyjna</span>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">Blog AutoMania</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">Praktyczne porady dotyczące pomocy drogowej, lawetowania i mechaniki samochodowej.</p>
    </div>
  </section>

  <!-- Posty lokalne SEO -->
  <section class="section bg-orange-50">
    <div class="wrap">
      <div class="text-center mb-10">
        <span class="eyebrow bg-orange-100 text-pd-orange">Zasięg działania</span>
        <h2 class="text-3xl font-bold text-gray-900">Laweta — obsługiwane miasta i gminy</h2>
        <p class="text-gray-500 mt-3">Działamy na terenie Kaszub, Trójmiasta i całego województwa pomorskiego</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {localPosts.map(post => (
          <a href={`${base}blog/${post.slug}`} class="bg-white rounded-2xl p-6 group block shadow-sm hover:shadow-md transition-shadow border border-orange-100">
            <h2 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-pd-orange transition-colors leading-snug">{post.title}</h2>
            <p class="text-gray-500 text-sm leading-relaxed mb-4">{post.excerpt}</p>
            <span class="inline-flex items-center gap-1 text-pd-orange font-semibold text-sm group-hover:gap-2 transition-all">
              Czytaj więcej
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-gray-50">
    <div class="wrap">
      <div class="text-center mb-10">
        <span class="eyebrow bg-orange-50 text-pd-orange">Porady motoryzacyjne</span>
        <h2 class="text-3xl font-bold text-gray-900">Artykuły i poradniki</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map(post => (
          <a href={`${base}blog/${post.slug}`} class="card group block p-0 overflow-hidden hover:shadow-xl transition-shadow">
            <div class="p-7">
              <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
                <span>{post.date}</span>
                <span>·</span>
                <span>{post.readTime} czytania</span>
              </div>
              <h2 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-pd-orange transition-colors leading-snug">{post.title}</h2>
              <p class="text-gray-500 text-sm leading-relaxed">{post.excerpt}</p>
              <span class="mt-5 inline-flex items-center gap-1.5 text-pd-orange font-semibold text-sm group-hover:gap-3 transition-all">
                Czytaj więcej
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-gray-950">
    <div class="wrap text-center">
      <h2 class="text-3xl font-extrabold text-white mb-4">Potrzebujesz pomocy teraz?</h2>
      <p class="text-gray-400 mb-8">AutoMania Andrzej Radomski — laweta i warsztat, dostępni 24/7.</p>
      <a href="tel:+48609116309" class="btn-primary text-lg px-8 py-4">Zadzwoń: 609 116 309</a>
    </div>
  </section>
</Layout>
