---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout
  title="Kontakt | AutoMania Andrzej Radomski — Pomoc Drogowa"
  description="Zadzwoń do nas — pomoc drogowa dostępna 24 godziny na dobę, 7 dni w tygodniu. AutoMania Andrzej Radomski, Kartuzy."
>
  <!-- Hero -->
  <section class="relative bg-gray-950 pt-20 pb-20 overflow-hidden">
    <div class="wrap relative text-center">
      <span class="eyebrow bg-white/10 text-gray-300">Kontakt</span>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">Zadzwoń — jesteśmy dostępni 24/7</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">Awaria nie czeka. Odbieramy telefon całą dobę, również w weekendy i święta.</p>
    </div>
  </section>

  <!-- Dane kontaktowe -->
  <section class="section bg-white">
    <div class="wrap max-w-3xl">

      <!-- Główny CTA telefoniczny -->
      <div class="bg-pd-orange rounded-2xl p-8 sm:p-12 text-center mb-10">
        <p class="text-orange-100 text-lg mb-3">Potrzebujesz pomocy drogowej?</p>
        <a href="tel:+48609116309" class="text-white font-extrabold text-4xl sm:text-5xl tracking-tight hover:underline">
          609 116 309
        </a>
        <p class="text-orange-100 mt-3 text-sm">Czynne całą dobę · 7 dni w tygodniu · Również w święta</p>
      </div>

      <!-- Dane firmy -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="card p-7 flex items-start gap-4">
          <div class="w-11 h-11 bg-orange-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-gray-900 mb-1">Właściciel</div>
            <span class="text-gray-500">Andrzej Radomski</span>
          </div>
        </div>

        <div class="card p-7 flex items-start gap-4">
          <div class="w-11 h-11 bg-orange-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-gray-900 mb-1">Adres warsztatu</div>
            <span class="text-gray-500">ul. Świerkowa 3<br/>83-300 Kartuzy</span>
          </div>
        </div>

        <div class="card p-7 flex items-start gap-4">
          <div class="w-11 h-11 bg-orange-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-gray-900 mb-1">E-mail</div>
            <a href="mailto:radomski.andrew@gmail.com" class="text-gray-500 hover:text-pd-orange transition-colors">radomski.andrew@gmail.com</a>
          </div>
        </div>

        <div class="card p-7 flex items-start gap-4">
          <div class="w-11 h-11 bg-orange-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-gray-900 mb-1">Godziny warsztatu</div>
            <span class="text-gray-500">Pon–Pt: 8:00–17:00<br/>Sobota: 8:00–14:00<br/><span class="text-pd-orange font-medium">Pomoc drogowa: całą dobę</span></span>
          </div>
        </div>
      </div>

      <!-- Mapa Google -->
      <div class="mt-10">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Znajdź nas na mapie</h2>
        <div class="rounded-2xl overflow-hidden border border-gray-100 shadow-sm" style="height: 380px;">
          <iframe
            src="https://maps.google.com/maps?q=%C5%9Awierkowa+3%2C+83-300+Kartuzy%2C+Polska&hl=pl&output=embed"
            width="100%"
            height="380"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="AutoMania Andrzej Radomski — ul. Świerkowa 3, Kartuzy"
          ></iframe>
        </div>
        <p class="text-sm text-gray-400 mt-2 text-center">ul. Świerkowa 3, 83-300 Kartuzy</p>
      </div>
    </div>
  </section>
</Layout>
