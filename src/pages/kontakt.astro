---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Kontakt | Pomoc Drogowa"
  description="Skontaktuj się z nami — pomoc drogowa dostępna 24 godziny na dobę, 7 dni w tygodniu."
>
  <!-- Hero -->
  <section class="relative bg-gray-950 pt-20 pb-20 overflow-hidden">
    <div class="wrap relative text-center">
      <span class="eyebrow bg-white/10 text-gray-300">Kontakt</span>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">Jesteśmy do Twojej dyspozycji</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">Zadzwoń lub napisz — odpowiadamy całą dobę.</p>
    </div>
  </section>

  <!-- Kontakt -->
  <section class="section bg-white">
    <div class="wrap">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Dane kontaktowe -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-8">Dane kontaktowe</h2>
          <ul class="space-y-6">
            <li class="flex items-start gap-4">
              <div class="w-11 h-11 bg-orange-50 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-900">Osoba kontaktowa</div>
                <span class="text-gray-500">Andrzej Radomski</span>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-11 h-11 bg-orange-50 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-900">Telefon (24/7)</div>
                <a href="tel:+48609116309" class="text-gray-500 hover:text-pd-orange transition-colors">609 116 309</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-11 h-11 bg-orange-50 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-900">E-mail</div>
                <a href="mailto:radomski.andrew@gmail.com" class="text-gray-500 hover:text-pd-orange transition-colors">radomski.andrew@gmail.com</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-11 h-11 bg-orange-50 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-900">Adres</div>
                <span class="text-gray-500">Świerkowa 3, 83-300 Kartuzy</span>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-11 h-11 bg-orange-50 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pd-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-900">Godziny pracy</div>
                <span class="text-gray-500">Dostępni 24 godziny na dobę, 7 dni w tygodniu</span>
              </div>
            </li>
          </ul>
        </div>

        <!-- Formularz -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-8">Napisz do nas</h2>
          <form class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="name">Imię i nazwisko</label>
              <input id="name" name="name" type="text" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-pd-orange/40 focus:border-pd-orange" placeholder="Jan Kowalski" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="phone">Telefon</label>
              <input id="phone" name="phone" type="tel" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-pd-orange/40 focus:border-pd-orange" placeholder="000 000 000" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="message">Wiadomość</label>
              <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-pd-orange/40 focus:border-pd-orange" placeholder="Opisz swoją sytuację..."></textarea>
            </div>
            <button type="submit" class="btn-primary w-full text-lg py-4">
              Wyślij wiadomość
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
